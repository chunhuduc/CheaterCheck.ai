{
  "name": "cheatercheck",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "db:generate": "pnpm --filter @cheatercheck/api db:generate",
    "db:migrate": "pnpm --filter @cheatercheck/api db:migrate",
    "db:seed": "pnpm --filter @cheatercheck/api db:seed"
  },
  "devDependencies": {
    "turbo": "^2.1.3",
    "typescript": "^5.6.2"
  },
  "engines": {
    "node": ">=20"
  }
}
