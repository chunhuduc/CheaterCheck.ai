{
  "name": "cheatercheck-ai",
  "private": true,
  "scripts": {
    "db:start": "docker-compose up -d harperdb",
    "db:stop": "docker-compose stop harperdb",
    "db:down": "docker-compose down",
    "db:seed": "node ./scripts/harperdb-seed.js",
    "dev:db": "npm run db:start && node ./scripts/wait-for-harperdb.js && npm run db:seed",
    "dev": "npm run dev:db && next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "cluster:up": "docker-compose up -d",
    "cluster:down": "docker-compose down",
    "cluster:stop": "docker-compose stop",
    "cluster:logs": "docker-compose logs -f",
    "cluster:bootstrap": "node ./scripts/cluster-bootstrap.js",
    "cluster:status": "docker-compose ps",
    "cluster:seed": "HARPERDB_URL=http://localhost:9925 node ./scripts/harperdb-seed.js",
    "crawler:up": "docker-compose up -d tinder-crawler-1-app tinder-crawler-1-hdb",
    "crawler:logs": "docker-compose logs -f tinder-crawler-1-app",
    "crawler:status": "docker-compose ps tinder-crawler-1-app tinder-crawler-1-hdb"
  },
  "dependencies": {
    "next": "13.5.6",
    "react": "18.2.0",
    "react-dom": "18.2.0"
  }
}
