# ---- shared ----
# Postgres (Neon). Use a pooled URL for the app, direct URL for migrations.
DATABASE_URL="postgresql://user:pass@host/db?sslmode=require"
DIRECT_URL="postgresql://user:pass@host/db?sslmode=require"

# ---- apps/api (NestJS) ----
API_PORT=4000
WEB_ORIGIN="http://localhost:3000"

# Stripe
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRICE_SINGLE="price_..."        # $18 single check
REPORT_UNLOCK_SUCCESS_URL="http://localhost:3000/report"

# Resend
RESEND_API_KEY="re_..."
RESEND_FROM="CheaterCheck <reports@cheatercheck.ai>"

# Ably (server publishes; uses the root/server key)
ABLY_API_KEY="xxxxx:yyyyy"

# worker
CRAWL_POLL_INTERVAL_MS=1500

# ---- apps/web (Next.js) ----
NEXT_PUBLIC_API_URL="http://localhost:4000"
# Ably client subscribes via a token endpoint on the API; no public key needed.
